{
  "version": 2,
  "builds": [
    { "src": "api/atualizar.py", "use": "@vercel/python" },
    { "src": "api/auth.py",      "use": "@vercel/python" },
    { "src": "index.html",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/atualizar", "dest": "/api/atualizar.py" },
    { "src": "/api/auth",      "dest": "/api/auth.py"      },
    { "src": "/(.*)",          "dest": "/index.html"       }
  ]
}
